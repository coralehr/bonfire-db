{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignore": ["**/*.d.ts"],
  "ignoreBinaries": ["bun", "docker"],
  "ignoreUnresolved": ["^bun:"],
  "ignoreDependencies": ["@ast-grep/cli", "jscpd"],
  "workspaces": {
    "loop": {
      "entry": ["src/index.ts", "src/agents/write.ts", "src/**/*.test.ts", "src/evals/*.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/core": {
      "entry": ["src/index.ts", "src/**/*.test.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/sql-on-fhir": {
      "entry": ["src/index.ts", "src/cli/**/*.ts", "src/**/*.test.ts"],
      "project": ["src/**/*.ts"]
    },
    "apps/api": {
      "entry": ["src/server.ts", "src/**/*.test.ts"],
      "project": ["src/**/*.ts"]
    },
    "seed": {
      "entry": ["index.ts"],
      "project": ["**/*.ts"]
    },
    ".": {
      "entry": [
        "scripts/synthetic-scan/index.ts",
        "scripts/sql-on-fhir/**/*.ts",
        "scripts/audit-demo/**/*.ts",
        "scripts/auth-demo/**/*.ts",
        "tests/sql-on-fhir/**/*.test.ts"
      ],
      "project": [
        "scripts/synthetic-scan/**/*.ts",
        "scripts/sql-on-fhir/**/*.ts",
        "scripts/audit-demo/**/*.ts",
        "scripts/auth-demo/**/*.ts",
        "tests/sql-on-fhir/**/*.ts"
      ]
    }
  }
}
