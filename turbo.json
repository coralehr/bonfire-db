{
  "$schema": "https://turborepo.dev/schema.json",
  "globalDependencies": [
    "bun.lock",
    "tsconfig.base.json",
    "tsconfig.json",
    "eslint.config.ts",
    "eslint.config.js",
    ".github/workflows/**"
  ],
  "globalEnv": ["CI"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "build/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "lint": {
      "dependsOn": [],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"],
      "env": ["DB_HOST_PORT", "DATABASE_URL", "MIGRATE_DATABASE_URL", "API_PORT"]
    },
    "@bonfire/sql-on-fhir#test": {
      "dependsOn": ["^build", "@bonfire/core#test", "@bonfire/api#test"],
      "outputs": ["coverage/**"],
      "env": ["DB_HOST_PORT", "DATABASE_URL", "MIGRATE_DATABASE_URL", "API_PORT"]
    },
    "gate": {
      "dependsOn": ["typecheck", "lint", "test", "build"],
      "cache": false
    }
  }
}
