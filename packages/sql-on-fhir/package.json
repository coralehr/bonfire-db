{
  "name": "@bonfire/sql-on-fhir",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "@bonfire/source": "./src/index.ts",
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint .",
    "test": "bun test --timeout 20000 --pass-with-no-tests src ../../tests/sql-on-fhir",
    "gate": "echo gated"
  },
  "dependencies": {
    "@bonfire/core": "workspace:*",
    "fhirpath": "4.10.1",
    "postgres": "3.4.9",
    "zod": "4.4.3"
  }
}
