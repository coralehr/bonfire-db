# Dependencies
node_modules/

# Build output
dist/
build/
.turbo/

# TypeScript incremental build state
*.tsbuildinfo

# Test & coverage artifacts
coverage/
test-results/
playwright-report/

# Environment & secrets — never commit
.env
.env.*
!.env.example

# Data exports & private fixtures — never commit PHI
exports/
fixtures/private/

# Logs & captured traces
*.log
*.trace
*.har

# Editor & OS noise
.DS_Store
.idea/

# Local agent / tooling state
.gstack/

# Per-agent worktrees (loop worktree) — ephemeral, same-volume, never committed
.worktrees/

# Key & certificate material — never commit
*.pem
*.key
*.p12
*.pfx
*.crt
id_rsa*

# Data dumps & tabular exports — PHI risk; track synthetic seed/migrations explicitly
*.csv
*.tsv
*.sql
*.parquet
*.ndjson
*.xlsx
!drizzle/**/*.sql
# The synthetic fixture corpus is committed on purpose (the seed reads it and
# scan:synthetic sweeps it every run); the blanket *.ndjson ignore above must
# not swallow it — that hid the files from CI while they existed locally.
!fixtures/synthetic/**/*.ndjson
!seed/**/*.sql

# Other credential files
.envrc
*credentials*
secrets.*

# Serena MCP local project cache
.serena/
